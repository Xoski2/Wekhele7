{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    }
  ],
  "rewrites": [
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/manifest.webmanifest", "destination": "/manifest.webmanifest" },
    { "source": "/registerSW.js", "destination": "/registerSW.js" },
    { "source": "/workbox-.*", "destination": "/workbox-:match" },
    { "source": "/icons/(.*)", "destination": "/icons/:match" },
    { "source": "/assets/(.*)", "destination": "/assets/:match" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
